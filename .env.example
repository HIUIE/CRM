# SmartTrade AI CRM local/LAN production config

# Server
NODE_ENV=production
HOST=0.0.0.0
PORT=3000

# Data paths
# Keep these paths OUTSIDE the frontend static directories (`dist/`, `public/`).
CRM_DB_PATH=/srv/smarttrade/data/erp_database_v2.sqlite
UPLOADS_DIR=/srv/smarttrade/data/uploads
BACKUP_DIR=/srv/smarttrade/backups

# Security
# Required in production. Use a long random string.
JWT_SECRET=replace-with-a-long-random-secret

# Required only when the production database is initialized for the first time.
# Change or disable root after creating your own admin account.
INITIAL_ADMIN_PASSWORD=replace-with-a-temporary-root-password

# Keep false for local/LAN HTTP. Use true only behind HTTPS.
COOKIE_SECURE=false

# Git auto-update: For private repos, create a token at GitHub Settings → Developer settings → Personal access tokens
# Give it `repo` scope. Then set it here so the system can check for updates.
# For public repos, leave empty — the API works without authentication.
# GITHUB_TOKEN=github_pat_xxxxxxxxxxxx

# AI providers are optional for the core CRM workflow.
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
