# SmartTrade AI CRM local/LAN production config

# Server
# Do not put NODE_ENV in Vite frontend build env files. Use `npm start` for production mode.
# NODE_ENV=production
HOST=0.0.0.0
PORT=3000

# Data paths
# Keep these paths OUTSIDE the frontend static directories (`dist/`, `public/`).
UPLOADS_DIR=./data/uploads
BACKUP_DIR=./data/backups

# Security
# Required in production. Use a long random string (at least 32 characters).
JWT_SECRET=replace-with-a-long-random-secret

# Required to encrypt sensitive settings like AI API Keys in the database.
# Use a unique 32-character string.
DB_ENCRYPTION_KEY=replace-with-a-32-char-random-string

# Required only when the production database is initialized for the first time. Use at least 12 characters.
# Change or disable root after creating your own admin account.
INITIAL_ADMIN_PASSWORD=replace-with-a-temporary-root-password

# Use true behind HTTPS. For local/LAN HTTP production testing, set ALLOW_INSECURE_COOKIES=true explicitly.
COOKIE_SECURE=false
ALLOW_INSECURE_COOKIES=true

# Git auto-update: For private repos, create a token at GitHub Settings → Developer settings → Personal access tokens
# Give it `repo` scope. Then set it here so the system can check for updates.
# For public repos, leave empty — the API works without authentication.
# GITHUB_TOKEN=github_pat_xxxxxxxxxxxx

# PostgreSQL (production database)
# Option A: connection string (most cloud providers give you one)
# DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# Option B: individual connection params
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DATABASE=smarttrade_crm
PG_USER=postgres
PG_PASSWORD=

# Enable SSL (required for cloud databases like Neon, Supabase, AWS RDS)
# PG_SSL=true

# AI providers are optional for the core CRM workflow.
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
